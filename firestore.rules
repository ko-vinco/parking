rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Structural Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidSpot(data) {
      return data.title is string && data.title.size() <= 100
        && data.neighborhood is string && data.neighborhood.size() <= 50
        && data.address is string && data.address.size() <= 150
        && data.pricePerHour is int && data.pricePerHour >= 0
        && data.availableHours is string && data.availableHours.size() <= 100
        && data.type is string && (data.type == 'villa' || data.type == 'apartment' || data.type == 'detached' || data.type == 'commercial' || data.type == 'land')
        && data.description is string && data.description.size() <= 500
        && data.hostPhone is string && data.hostPhone.size() <= 30
        && data.coordinates is map
        && data.status is string && (data.status == 'available' || data.status == 'reserved');
    }

    function isValidBooking(data) {
      return data.id is string && data.id.size() <= 50
        && data.spotId is string && data.spotId.size() <= 128
        && data.spotTitle is string && data.spotTitle.size() <= 150
        && data.spotAddress is string && data.spotAddress.size() <= 200
        && data.startTime is string && data.startTime.size() <= 100
        && data.endTime is string && data.endTime.size() <= 100
        && data.totalPrice is int && data.totalPrice >= 0
        && data.status is string && (data.status == 'active' || data.status == 'completed' || data.status == 'cancelled')
        && data.carNumber is string && data.carNumber.size() <= 30;
    }

    // Spots Collection (Public Discovery)
    match /spots/{spotId} {
      allow read: if true;
      allow create: if isValidSpot(request.resource.data) && isValidId(spotId);
      allow update: if isValidSpot(request.resource.data) && isValidId(spotId);
      allow delete: if false;
    }

    // Bookings Collection (Public Shared Order ledger)
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidBooking(request.resource.data) && isValidId(bookingId);
      allow update: if isValidBooking(request.resource.data) && isValidId(bookingId);
      allow delete: if true;
    }
  }
}
