{
  "entities": {
    "ParkingSpot": {
      "title": "ParkingSpot",
      "description": "인천 검단 지역의 공유 가능한 빈 주차 구역 정보",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "주차공간 고유 식별자" },
        "title": { "type": "string", "description": "주차공간 구역 명칭" },
        "neighborhood": { "type": "string", "description": "소속 법정동 (아라동, 원당동, 당하동, 마전동, 불로동, 오류동)" },
        "address": { "type": "string", "description": "정확한 상세도로명 및 지번 주소" },
        "pricePerHour": { "type": "integer", "description": "시간당 이용 요금" },
        "availableHours": { "type": "string", "description": "개방 및 대여 가능 시간" },
        "type": { "type": "string", "enum": ["villa", "apartment", "detached", "commercial", "land"], "description": "주차 구역 형태" },
        "features": { "type": "array", "description": "제공 안전/편의 시설 목록" },
        "description": { "type": "string", "description": "이용 안내 세부 메시지" },
        "hostPhone": { "type": "string", "description": "호스트 안심 연락처" },
        "coordinates": { "type": "object", "description": "미니맵 렌더용 격자 좌표 { x, y }" },
        "status": { "type": "string", "enum": ["available", "reserved"], "description": "실시간 예약 가능 여부 상태" },
        "createdAt": { "type": "string", "format": "date-time", "description": "주차공간 공유 등록 시간" },
        "totalRatingsCount": { "type": "integer", "description": "평가 건수" },
        "averageRating": { "type": "number", "description": "평균 별점 평점" }
      },
      "required": ["id", "title", "neighborhood", "address", "pricePerHour", "availableHours", "type", "description", "hostPhone", "coordinates", "status", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "사용자가 생성한 실시간 예약 및 비대면 주차 제어 거래 내역",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "예약 주문 고유 식별번호" },
        "spotId": { "type": "string", "description": "대상 주차공간의 ID" },
        "spotTitle": { "type": "string", "description": "주차장 이름 기록" },
        "spotAddress": { "type": "string", "description": "주차장 도로명 주소 기록" },
        "startTime": { "type": "string", "description": "대여 시작 일시 문자열" },
        "endTime": { "type": "string", "description": "대여 종료 예정 일시" },
        "totalPrice": { "type": "integer", "description": "대여 시간 비례 최종 이용요금" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"], "description": "현재 대여 거래 흐름 진행상태" },
        "reservedAt": { "type": "string", "format": "date-time", "description": "예약 승인 타임스탬프" },
        "carNumber": { "type": "string", "description": "투입 주차 차량번호" }
      },
      "required": ["id", "spotId", "spotTitle", "spotAddress", "startTime", "endTime", "totalPrice", "status", "reservedAt", "carNumber"]
    }
  },
  "firestore": {
    "spots/{spotId}": {
      "schema": "ParkingSpot",
      "description": "실시간 검단 공유 주차장 목록 공간 데이터베이스"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "사용자 차량 대여 신청 및 진행 내역 예약기록부"
    }
  }
}
